You are given a list of words and an integer K.
Write a function that returns the K most frequent words.
If two words have the same frequency, return them in alphabetical order.

words = ["ai","ml","ai","rag","ml","ai","python"]
k = 2
Output:
["ai","ml"]

#brute force
-nested loop
def most_freq():
    result = []
    found = []

    while len(result) < k:
        max_word = ""
        max_freq = -1

        for i in range(len(words)):

            if words[i] in found:
                continue

            count = 0

            for j in range(len(words)):
                if words[i] == words[j]:
                    count += 1

            if count > max_freq:
                max_freq = count
                max_word = words[i]

            elif count == max_freq:
                if words[i] < max_word:
                    max_word = words[i]

        result.append(max_word)
        found.append(max_word)

    return result

print(most_freq())


Time Complexity: O(n²)
Space Complexity: O(k)






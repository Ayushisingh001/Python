Q.Write a simple timing decorator.
A timing decorator is a decorator that measures how long a function takes to execute by recording the start time and end time and printing their difference.
import time
def decorator(func):
    def wrapper():
        start=time.time()
        print("start")
        func()
        end=time.time()
        print("end")
        print("execution time is",end-start,"seconds")
    return wrapper

@decorator
def hello():
    for i in range(1000000):
        pass
hello()

